# Supabase Settings (NEXT_PUBLIC_ prefix required for client-side access in Next.js)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API Settings (server-side only — never expose to client)
# Run: npx vercel env pull .env.local
GEMINI_API_KEY=your_gemini_api_key_here

# Supadata YouTube transcript API (server-side, optional) — 듣고 읽기 /api/media/captions step 5 폴백.
# 없으면 자막 자동 폴백만 조용히 스킵(핵심 정독 흐름·.srt/.vtt 직접 업로드는 불변). https://supadata.ai
SUPADATA_API_KEY=your_supadata_api_key_here

# Cron 인증 시크릿 (server-side) — /api/cron/* GET 요청의 Bearer 토큰.
# 미설정 시 cron 라우트는 fail-closed(요청 거부)로 동작한다.
CRON_SECRET=your_cron_secret_here

# Claude ↔ Codex AI Relay (server-side only — never expose to client)
# 두 토큰은 서로 다른 32자 이상 난수. 에이전트 로컬에는 자기 토큰만 MANABI_AI_RELAY_TOKEN으로 둔다.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
MANABI_AI_RELAY_CLAUDE_TOKEN=your_long_random_claude_token_here
MANABI_AI_RELAY_CODEX_TOKEN=your_long_random_codex_token_here
MANABI_AI_RELAY_URL=http://localhost:3000/api/ai-relay
MANABI_AI_RELAY_TOKEN=your_current_agent_token_here
