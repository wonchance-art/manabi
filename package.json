{
  "name": "anatomy-studio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "predev": "node scripts/world/build-overworld-fixture.mjs --check && node scripts/world/build-world-node-geo-manifest.mjs --check && node scripts/copy-pdf-worker.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/check-content.mjs && node scripts/check-reading.mjs && node scripts/world/build-overworld-fixture.mjs --check && node scripts/world/build-world-node-geo-manifest.mjs --check && node scripts/update-sw-version.mjs && node scripts/copy-pdf-worker.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check:reading": "node scripts/check-reading.mjs",
    "check:overworld-fixture": "node scripts/world/build-overworld-fixture.mjs --check",
    "build:overworld-map-previews": "node scripts/world/build-overworld-map-previews.mjs",
    "build:world-node-geo": "node scripts/world/build-world-node-geo-manifest.mjs",
    "check:world-node-geo": "node scripts/world/build-world-node-geo-manifest.mjs --check",
    "build:overworld-transport-nodes": "node scripts/world/build-overworld-transport-nodes.mjs --manifest scripts/world/overworld-transport-nodes-apac-v1.json --output-dir public/assets/overworld/asia-pacific-transport-nodes-preview-v1 && node scripts/world/build-overworld-transport-nodes.mjs --manifest scripts/world/overworld-transport-nodes-emea-v1.json --output-dir public/assets/overworld/europe-mediterranean-middle-east-transport-nodes-preview-v1",
    "check:overworld-transport-nodes": "node scripts/world/build-overworld-transport-nodes.mjs --check --manifest scripts/world/overworld-transport-nodes-apac-v1.json --output-dir public/assets/overworld/asia-pacific-transport-nodes-preview-v1 && node scripts/world/build-overworld-transport-nodes.mjs --check --manifest scripts/world/overworld-transport-nodes-emea-v1.json --output-dir public/assets/overworld/europe-mediterranean-middle-east-transport-nodes-preview-v1",
    "test": "vitest run",
    "e2e": "node --test --test-concurrency=1 e2e/smoke.e2e.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@plussub/srt-vtt-parser": "^2.0.5",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.2",
    "canvas-confetti": "^1.9.4",
    "galmuri": "^2.40.3",
    "kuromojin": "^3.0.1",
    "next": "^15.5.14",
    "pdfjs-dist": "^4.10.38",
    "phaser": "^3.90.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-youtube": "^10.1.0",
    "ts-fsrs": "^5.3.2",
    "web-push": "^3.6.7",
    "wink-lemmatizer": "^3.0.4",
    "youtube-transcript": "^1.3.0",
    "youtubei.js": "17.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "playwright-core": "^1.61.0",
    "vitest": "^4.1.4"
  }
}
